[global]
    monitor = 0
    font = JetBrains Mono Nerd Font 10
    follow = mouse
    width = (200, 300)
    height = (0, 300)
    origin = top-right
    offset = 10x10
    notification_limit = 5
    indicate_hidden = yes
    transparency = 0
    separator_height = 2
    padding = 15
    horizontal_padding = 15
    text_icon_padding = 0
    frame_width = 2
    frame_color = "#89b4fa"
    gap_size = 6
    separator_color = frame
    sort = yes
    idle_threshold = 120
    show_age_threshold = 60
    icon_position = left
    min_icon_size = 48
    max_icon_size = 64
    corner_radius = 15
    mouse_left_click = close_current
    mouse_middle_click = do_action, close_current
    mouse_right_click = close_all
    progress_bar = true
    progress_bar_height = 10
    progress_bar_frame_width = 1
    progress_bar_min_width = 150
    progress_bar_max_width = 300

[urgency_low]
    background = "#1e1e2e"
    foreground = "#cdd6f4"
    frame_color = "#585b70"
    timeout = 5
    default_icon = dialog-information

[urgency_normal]
    background = "#1e1e2e"
    foreground = "#cdd6f4"
    frame_color = "#89b4fa"
    timeout = 10
    default_icon = dialog-information

[urgency_critical]
    background = "#1e1e2e"
    foreground = "#cdd6f4"
    frame_color = "#fab387"
    timeout = 0
    default_icon = dialog-warning
